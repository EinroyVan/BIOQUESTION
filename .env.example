# Google Gemini (default — local .env keeps these names)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-3.5-flash

# Optional: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: OpenAI-compatible APIs (DeepSeek, Ollama, local gateways, etc.)
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=deepseek-chat

# Optional: default LLM provider for CLI (google | openai | anthropic | openai_compatible)
LLM_PROVIDER=google
